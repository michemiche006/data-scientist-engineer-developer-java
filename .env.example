# Bedrock API key authentication
# Do not set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY for this tutorial.
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# Bedrock settings
BEDROCK_AWS_REGION=us-east-1
BEDROCK_CHAT_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_EMBEDDINGS_MODEL_ID=amazon.titan-embed-text-v2:0

# Optional: run the app server on a different port
SERVER_PORT=3000
